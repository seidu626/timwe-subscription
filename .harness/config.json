      "module": "agent_supervisor.harnesses.dependency_impact.DependencyImpactHarness",
      "config": {}
    },
    "state_machine": {
      "enabled": true,
      "module": "agent_supervisor.harnesses.state_machine.StateMachineHarness",
      "config": {}
    },
    "verification": {
      "enabled": true,
      "module": "agent_supervisor.harnesses.verification.VerificationHarness",
      "config": {}
    },
    "review": {
      "enabled": true,
      "module": "agent_supervisor.harnesses.review.ReviewHarness",
      "config": {}
    }
  }
