                "responses": {
                    "202": {
                        "description": "Accepted with jobId",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request payload or error generating MSISDNS",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
