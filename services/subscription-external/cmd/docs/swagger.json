        "/api/v1/subscription-external/backfill": {
            "post": {
                "description": "If msisdns not provided, finds active MSISDNs missing the provided product_ids and enqueues opt-in jobs.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Subscriptions"
                ],
                "summary": "Backfill subscriptions for MSISDNs missing specified products (async)",
                "parameters": [
                    {
                        "description": "Backfill Request",
                        "name": "message",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.BackfillRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted with jobId",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request payload",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/subscription-external/batch": {
            "post": {
                "description": "Enqueue a batch job and return jobId to poll status.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Subscriptions"
