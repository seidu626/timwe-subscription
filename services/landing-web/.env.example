# Landing Page Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# API Configuration
# ============================================

# Backend acquisition API URL
NEXT_PUBLIC_ACQUISITION_API_URL=http://localhost:8084

# Site URL for SEO canonical links and structured data
NEXT_PUBLIC_SITE_URL=https://subscribe.nouveauriche.com

# ============================================
# Analytics & Tracking (Optional - can be set per-campaign)
# ============================================

# Global Facebook Pixel ID (used as fallback if no campaign-specific pixel)
# NEXT_PUBLIC_FB_PIXEL_ID=

# Global Google Analytics Measurement ID (GA4)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Global Google Ads ID (for conversion tracking)
# NEXT_PUBLIC_GOOGLE_ADS_ID=

# Global TikTok Pixel ID
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ============================================
# Feature Flags
# ============================================

# Enable analytics debug panel in production (not recommended)
# NEXT_PUBLIC_DEBUG_ANALYTICS=false

# Enable A/B testing framework
# NEXT_PUBLIC_ENABLE_EXPERIMENTS=true

# ============================================
# Build Configuration
# ============================================

# Build ID for cache busting (auto-generated if not set)
# BUILD_ID=

# Node environment
NODE_ENV=development

# --------------------------------------------------------------------
# Sentry
# --------------------------------------------------------------------
# Sentry DSN for frontend/backend error monitoring
SENTRY_DSN=

# Optional release metadata for grouping and source tracking
SENTRY_RELEASE=

# Sentry environment tag (development, staging, production)
SENTRY_ENVIRONMENT=development

# ============================================
# Header Enrichment (HE) Simulation (Staging/Local Only)
# ============================================
# SECURITY: These settings MUST be disabled in production.
# The HE simulator allows testing subscription flows without real MNO HE.

# Master switch - set to 'true' to enable HE simulation (default: false)
# HE_SIMULATION_ENABLED=false

# JWT signing secret for simulation tokens (REQUIRED if HE_SIMULATION_ENABLED=true)
# Generate with: openssl rand -base64 32
# HE_SIM_SECRET=

# Cookie name for the simulation token (default: he_sim_token)
# HE_SIM_COOKIE_NAME=he_sim_token

# Token TTL in seconds (default: 180 = 3 minutes)
# HE_SIM_TTL_SECONDS=180
