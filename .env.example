# Local Docker Compose example values.
# Copy to .env for local development and replace all placeholder secrets.

POSTGRESQL_VERSION=16
APP_DATABASE_POSTGRESQL_HOST=database
APP_DATABASE_POSTGRESQL_PORT=5432
PG_USER=subscription_manager
PG_PASSWORD=replace-with-local-postgres-password
PG_DB=subscription_manager

JWT_SECRET=replace-with-local-jwt-secret

TIMWE_API_KEY=replace-with-timwe-api-key
TIMWE_PSK=replace-with-timwe-psk
INTERNAL_API_SECRET=replace-with-local-internal-api-secret

ADMIN_AUTH0_DOMAIN=dev-chliep5q.auth0.com
ADMIN_AUTH0_AUDIENCE=https://dev-chliep5q.auth0.com/api/v2/

PGADMIN_DEFAULT_EMAIL=admin@example.test
PGADMIN_DEFAULT_PASSWORD=replace-with-local-pgadmin-password
PGADMIN_LISTEN_PORT=80

NOTIFICATION_WORKER_MT_BASE_URL=http://subscription-external:8083
NOTIFICATION_WORKER_MT_CHANNEL=SMS

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-local-minio-password

SUBSCRIPTION_EXTERNAL_URL=http://krakend:8080
NEXT_PUBLIC_ACQUISITION_API_URL=http://localhost:8080

CAMPAIGN_ASSET_STORAGE_ENABLED=true
CAMPAIGN_ASSET_STORAGE_ENDPOINT=minio:9000
CAMPAIGN_ASSET_STORAGE_BUCKET=campaign-assets
CAMPAIGN_ASSET_STORAGE_REGION=us-east-1
CAMPAIGN_ASSET_STORAGE_ACCESS_KEY_ID=minioadmin
CAMPAIGN_ASSET_STORAGE_SECRET_ACCESS_KEY=replace-with-local-minio-password
CAMPAIGN_ASSET_STORAGE_USE_SSL=false
CAMPAIGN_ASSET_STORAGE_PUBLIC_BASE_URL=http://localhost:9100/campaign-assets
CAMPAIGN_ASSET_STORAGE_KEY_PREFIX=campaign-backgrounds
CAMPAIGN_ASSET_STORAGE_MAX_UPLOAD_BYTES=2097152
CAMPAIGN_ASSET_STORAGE_PRESIGN_EXPIRY=10m
