{{ define "HEApiEndpoint" }}
{
    "endpoint": "{{ .Endpoint }}",
    "method": "{{ .METHOD }}",
    "output_encoding": "no-op",
    "extra_config": {
        "github.com/devopsfaith/krakend/http": {
            "return_error_details": true
        }
    },
    "input_query_strings": ["*"],
    "input_headers": [
        "X-HE-Trusted-Proxy",
        "X-MSISDN",
        "X-UP-CALLING-LINE-ID",
        "X_WAP_NETWORK_CLIENT_MSISDN",
        "X-MCC",
        "X-MNC",
        "X-Operator-ID",
        "X-HE-Bootstrap-Token"
    ],
    "headers_to_pass": [
        "X-HE-Trusted-Proxy",
        "X-MSISDN",
        "X-UP-CALLING-LINE-ID",
        "X_WAP_NETWORK_CLIENT_MSISDN",
        "X-MCC",
        "X-MNC",
        "X-Operator-ID",
        "X-HE-Bootstrap-Token"
    ],
    "backend": [
        {
            "url_pattern": "{{ .BackendUrlPattern }}",
            "encoding": "no-op",
            "sd": "static",
            "method": "{{ .METHOD }}",
            "extra_config": {
                "github.com/devopsfaith/krakend/http": {
                    "return_error_details": true
                },
                "github.com/devopsfaith/krakend-ratelimit/juju/proxy": {
                    "maxRate": 100,
                    "capacity": 200,
                    "strategy": "token-bucket"
                },
                "github.com/devopsfaith/krakend/logging": {
                    "level": "INFO",
                    "prefix": "[HE API]",
                    "stdout": true
                },
                "github.com/devopsfaith/krakend-cors": {
                    "allow_origins": ["*"],
                    "allow_methods": ["GET", "POST", "OPTIONS"],
                    "max_age": "12h"
                }
            },
            "host": ["{{ .BackendHost }}"],
            "disable_host_sanitize": true,
            "headers_to_pass": [
                "X-HE-Trusted-Proxy",
                "X-MSISDN",
                "X-UP-CALLING-LINE-ID",
                "X_WAP_NETWORK_CLIENT_MSISDN",
                "X-MCC",
                "X-MNC",
                "X-Operator-ID",
                "X-HE-Bootstrap-Token"
            ]
        }
    ]
}
{{ end }}
