{{ define "LandingWebEndpoint" }}
{
    "endpoint": "{{ .Endpoint }}",
    "method": "{{ .METHOD }}",
    "output_encoding": "no-op",
    "extra_config": {
        "github.com/devopsfaith/krakend/http": {
            "return_error_details": true
        }
    },
    "backend": [
        {
            "url_pattern": "{{ .BackendUrlPattern }}",
            "encoding": "no-op",
            "sd": "static",
            "method": "{{ .METHOD }}",
            "extra_config": {
                "github.com/devopsfaith/krakend/http": {
                    "return_error_details": true
                },
                "github.com/devopsfaith/krakend-cors": {
                    "allow_origins": ["*"],
                    "allow_methods": ["GET", "POST"],
                    "max_age": "12h"
                }
            },
            "host": ["{{ .BackendHost }}"],
            "disable_host_sanitize": true
        }
    ]
}
{{ end }}
