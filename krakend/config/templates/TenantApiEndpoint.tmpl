{{ define "TenantApiEndpoint" }}
{
    "endpoint": "{{ .Endpoint }}",
    "method": "{{ .METHOD }}",
    "output_encoding": "no-op",
    "extra_config": {
        "github.com/devopsfaith/krakend/http": {
            "return_error_details": true
        }
    },
    "headers_to_pass": [
        "external-tx-id"
    ],
    "input_query_strings": [
        "tenant_key",
        "channel_key",
        "external-tx-id"
    ],
    "backend": [
        {
            "url_pattern": "{{ .BackendUrlPattern }}",
            "encoding": "json",
            "sd": "static",
            "method": "{{ .METHOD }}",
            "extra_config": {
                "github.com/devopsfaith/krakend/http": {
                    "return_error_details": true
                },
                "github.com/devopsfaith/krakend-ratelimit/juju/proxy": {
                    "maxRate": 10,
                    "capacity": 20,
                    "strategy": "token-bucket"
                },
                "github.com/devopsfaith/krakend/logging": {
                    "level": "INFO",
                    "prefix": "[API Gateway]",
                    "stdout": true
                },
                "github.com/devopsfaith/krakend-cors": {
                    "allow_origins": ["*"],
                    "allow_methods": ["GET", "POST", "DELETE", "PUT"],
                    "max_age": "12h"
                },
                "modifier/martian": {
                    "fifo.Group": {
                        "scope": ["request"],
                        "aggregateErrors": true,
                        "modifiers": [
                            {
                                "header.Modifier": {
                                    "scope": ["request"],
                                    "name": "X-Tenant-Key",
                                    "value": "{tenant_key}"
                                }
                            },
                            {
                                "header.Modifier": {
                                    "scope": ["request"],
                                    "name": "X-Channel-Key",
                                    "value": "{channel_key}"
                                }
                            }
                        ]
                    }
                }
            },
            "host": ["{{ .BackendHost }}"],
            "disable_host_sanitize": true,
            "headers_to_pass": [
                "external-tx-id"
            ]
        }
    ]
}
{{ end }}
